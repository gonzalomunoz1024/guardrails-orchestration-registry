# GitHub OAuth App credentials (Device Flow - no secret needed!)
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Note: Device Flow doesn't require a callback URL
VITE_GITHUB_CLIENT_ID=your_github_client_id

# GitHub Personal Access Token for PR creation
# This PAT is used for all GitHub operations (fork, commit, PR)
# User OAuth is still used for identity/attribution
# Create at: https://github.com/settings/tokens (classic token with 'repo' scope)
VITE_GITHUB_PAT=your_personal_access_token

# GitHub repository for PR creation
VITE_GITHUB_REPO_OWNER=your-org
VITE_GITHUB_REPO_NAME=policy-registry

# Backend API URL - Guardrails Orchestrator Service
# Handles: registry CRUD, OPA evaluation passthrough
# All endpoints are absolute paths under /v1/utilities — no /api prefix.
# VITE_API_BASE_URL=http://localhost:8181
